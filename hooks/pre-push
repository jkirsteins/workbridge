#!/usr/bin/env bash
set -euo pipefail

# Check for unstaged changes
if ! git diff --quiet; then
    echo "ERROR: You have unstaged changes. Please stage or stash them before pushing."
    git diff --stat
    exit 1
fi

# Check for untracked files
untracked=$(git ls-files --others --exclude-standard)
if [ -n "$untracked" ]; then
    echo "ERROR: You have untracked files. Please add, stash, or .gitignore them before pushing."
    echo "$untracked"
    exit 1
fi

echo "=== pre-push: running tests ==="
# Clear git env vars so child git processes in integration tests operate on
# their temp directories, not on this repo. Defense-in-depth for the
# env_remove() calls in Rust code.
unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE GIT_COMMON_DIR
cargo test --all-features
echo "All tests passed."
