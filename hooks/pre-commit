#!/usr/bin/env bash
set -euo pipefail

# All per-file staged-content checks below read the index (via
# `git show ":$f"`), NOT the working tree. This is important for
# correctness: a contributor can `git add` a file, then edit it
# further in the working tree, then run `git commit`. In that case
# the commit creates an object from the index content, so that is
# the content the hook must validate. Greping the working tree
# would let stage-then-edit-away bypasses slip through. The helper
# `staged_content` below is the single entry point for reading an
# index blob as text.
#
# Files that are staged for deletion will not have an index blob;
# `git show` will fail with a nonzero exit code. We detect that
# case up front (via the file's status letter) and skip it, since
# a deletion cannot introduce a violation.

staged_content() {
    # Print the staged (index) content for a path, or nothing on
    # failure. Callers are responsible for pre-filtering deletions.
    git show ":$1" 2>/dev/null
}

# List staged paths that end in `.rs` and are NOT staged for
# deletion. Output one path per line.
list_staged_rs_added_or_modified() {
    git diff --cached --name-status -- '*.rs' \
        | awk '$1 != "D" { print $2 }'
}

# Check whether the staged content of a file matches the given
# ERE. Returns 0 on match, 1 on no-match. Usage:
#
#     if staged_matches "$path" 'regex'; then ...
#
# We materialize the staged blob into a file and grep against that
# file, rather than piping the content through `grep -q`, because
# `grep -q` exits as soon as it finds a match, SIGPIPE-kills the
# upstream `printf`/`git show`, and with `set -o pipefail` makes
# the whole pipeline exit 141. Inside an `if` condition that 141
# is treated as "false" - so matches in large staged files
# (src/app.rs is ~1MB) near the top of the buffer silently went
# undetected by the previous `printf '%s' "$content" | grep -q`
# pattern. Materializing to a tempfile eliminates the pipe and
# therefore the SIGPIPE race entirely; the tempfile is removed
# via the parent script's EXIT trap.
staged_matches() {
    local path="$1" pattern="$2"
    local tmp="${HOOK_STAGED_SCRATCH_DIR}/$(printf '%s' "$path" | tr '/' '_').blob"
    if ! git show ":$path" >"$tmp" 2>/dev/null; then
        return 1
    fi
    grep -qE -- "$pattern" "$tmp"
}

# Scratch directory for materialized staged blobs. Created once
# and removed on EXIT so no hook run leaks files. `mktemp -d`
# produces a process-unique path under `$TMPDIR` so parallel hook
# runs (rare, but possible in some git workflows) do not collide.
HOOK_STAGED_SCRATCH_DIR="$(mktemp -d -t workbridge-pre-commit-XXXXXX)"
trap 'rm -rf "$HOOK_STAGED_SCRATCH_DIR"' EXIT

echo "=== pre-commit: checking format ==="
cargo fmt -- --check
echo "Format OK."

echo "=== pre-commit: running clippy ==="
cargo clippy --all-targets --all-features -- -D warnings
echo "Clippy OK."

echo "=== pre-commit: checking for bare Command::new(\"git\") ==="
bare_git_files=""
while IFS= read -r f; do
    [ -z "$f" ] && continue
    if staged_matches "$f" 'Command::new\("git"\)'; then
        if ! staged_matches "$f" 'env_remove\("GIT_DIR"\)|git_command\(\)'; then
            bare_git_files="$bare_git_files $f"
        fi
    fi
done < <(list_staged_rs_added_or_modified)
if [ -n "$bare_git_files" ]; then
    echo "ERROR: These files use Command::new(\"git\") without env clearing:"
    echo "$bare_git_files"
    echo "Use worktree_service::git_command() or add .env_remove(\"GIT_DIR\") etc."
    exit 1
fi
echo "Git env check OK."

echo "=== pre-commit: checking for bare agent binary spawns ==="
# Every LLM CLI spawn must go through the AgentBackend trait in
# src/agent_backend.rs. Hard-coding Command::new("claude") (or any
# future agent binary) elsewhere bypasses the trait and will not
# work when a second backend is wired. Same enforcement pattern as
# the Command::new("git") check above.
bare_agent_files=""
while IFS= read -r f; do
    [ -z "$f" ] && continue
    # agent_backend.rs is the ONLY file allowed to mention the binary name.
    if [ "$(basename "$f")" = "agent_backend.rs" ]; then
        continue
    fi
    if staged_matches "$f" 'Command::new\("(claude|codex)"'; then
        bare_agent_files="$bare_agent_files $f"
    fi
done < <(list_staged_rs_added_or_modified)
if [ -n "$bare_agent_files" ]; then
    echo "ERROR: These files spawn an agent binary directly:"
    echo "$bare_agent_files"
    echo "Use agent_backend.command_name() and a build_*_command() trait method instead."
    echo "See src/agent_backend.rs and docs/harness-contract.md."
    exit 1
fi
echo "Agent spawn check OK."

echo "=== pre-commit: checking for bypasses of src/side_effects/ ==="
# src/side_effects/ is the ONLY place allowed to reach the real system
# clipboard, directories::ProjectDirs / BaseDirs / UserDirs,
# std::env::home_dir, std::env::temp_dir, or wall-clock time. Every
# other file must route through side_effects:: wrappers (for
# production paths) or tempfile::tempdir() (for test scratch dirs).
#
# The patterns cover BOTH fully-qualified paths
# (`std::env::temp_dir()`, `arboard::Clipboard`) AND the `use ...;`
# aliasing forms that would otherwise let a contributor import the
# symbol under a short name and call it bare (e.g.
# `use std::env::temp_dir;` then `temp_dir()`). Aliasing defeats
# the simple grep from a single-axis pattern, which is why the
# regex splits into two OR groups: one for qualified references,
# one for the `use` imports of the gated roots.
#
# As a defense-in-depth layer we also flag bare calls to
# `temp_dir()` / `home_dir()` that are not preceded by `.` (method
# call) or `::`, in case a contributor writes `use std::env;` then
# calls `env::temp_dir()`. `env::temp_dir` is caught by the
# second OR branch; a bare `temp_dir()` that survives both has no
# legitimate source and must be flagged.
#
# The regex also rejects wall-clock-reading patterns that sneak
# past `Instant::now` / `SystemTime::now` / `thread::sleep`:
#
# - `.elapsed(` is short for `Instant::now() - *self` and leaks
#   the real clock even when `self` was captured via the mock
#   `instant_now()` wrapper. Use `crate::side_effects::clock::
#   elapsed_since(start)` instead, which diffs against the mock
#   clock in tests and against the real clock in production.
# - `recv_timeout(`, `recv_deadline(`, `wait_timeout(`,
#   `park_timeout(` all read the monotonic clock under the hood
#   to bound a wait. Tests must use the shared
#   `crate::side_effects::clock::bounded_recv` helper, which polls
#   `try_recv` on a mock-clock-driven timer. See
#   `src/side_effects/clock.rs` for the helper itself and
#   `src/app.rs::tests::manage_unmanage_sets_fetcher_repos_changed`
#   (via the caller at ~22569) for a canonical usage.
#
# `.duration_since(` is intentionally NOT in the forbidden list:
# the codebase calls `SystemTime::duration_since(UNIX_EPOCH)` and
# `Instant::saturating_duration_since(other)` in dozens of
# legitimate places where both operands are already gated values.
# Those calls do not read wall-clock time - the time was read
# when the operand was captured. Adding `.duration_since(` would
# produce too many false positives to be useful.
#
# See docs/superpowers/specs/2026-04-18-test-side-effects-audit-design.md
# and the corresponding P0 rule in CLAUDE.md.
bare_sideeffect_files=""
while IFS= read -r f; do
    [ -z "$f" ] && continue
    # side_effects/* is allowed to mention the gated symbols.
    case "$f" in
        src/side_effects/*) continue ;;
    esac
    if staged_matches "$f" 'arboard::|directories::(ProjectDirs|BaseDirs|UserDirs)|std::env::home_dir|std::env::temp_dir|Instant::now|SystemTime::now|thread::sleep|\.elapsed\(|recv_timeout\(|recv_deadline\(|wait_timeout\(|park_timeout\(|^[[:space:]]*use[[:space:]]+arboard(::|;|[[:space:]])|^[[:space:]]*use[[:space:]]+directories::(ProjectDirs|BaseDirs|UserDirs)|^[[:space:]]*use[[:space:]]+std::env::(temp_dir|home_dir)|^[[:space:]]*use[[:space:]]+std::time::(Instant|SystemTime)|^[[:space:]]*use[[:space:]]+std::thread::sleep|^[[:space:]]*use[[:space:]]+std::thread;'; then
        bare_sideeffect_files="$bare_sideeffect_files $f"
    fi
done < <(list_staged_rs_added_or_modified)
if [ -n "$bare_sideeffect_files" ]; then
    echo "ERROR: These files bypass src/side_effects/:"
    echo "$bare_sideeffect_files"
    echo ""
    echo "Host-visible APIs (arboard, directories::ProjectDirs/BaseDirs/UserDirs,"
    echo "std::env::home_dir, std::env::temp_dir, Instant::now, SystemTime::now,"
    echo "thread::sleep) must be reached through"
    echo "crate::side_effects::{clipboard, clock, paths} or tempfile::tempdir()."
    echo ""
    echo "Wall-clock-reading patterns (.elapsed(), recv_timeout(),"
    echo "recv_deadline(), wait_timeout(), park_timeout()) must be replaced"
    echo "with crate::side_effects::clock::elapsed_since(...) for elapsed"
    echo "or crate::side_effects::clock::bounded_recv(...) for receives."
    echo ""
    echo "Both qualified references (e.g. 'std::env::temp_dir()') and 'use'"
    echo "imports (e.g. 'use std::env::temp_dir;') are rejected. See:"
    echo "  - docs/TESTING.md 'Side-effect gating module'"
    echo "  - src/side_effects/mod.rs"
    echo "  - CLAUDE.md 'Severity overrides' (P0 rule)"
    exit 1
fi
echo "Side-effect gate check OK."

echo "=== pre-commit: file-size budgets ==="
./hooks/budget-check.sh

echo "=== pre-commit: ratatui built-in preference (warn-only) ==="
./hooks/ratatui-builtin-check.sh

echo "=== pre-commit: typos (skipped if tool missing) ==="
if command -v typos >/dev/null 2>&1; then
    typos --config typos.toml
    echo "typos OK."
else
    echo "typos not installed; skipping. Install with: cargo install typos-cli"
fi

echo "=== pre-commit: cargo-deny (skipped if tool missing) ==="
if command -v cargo-deny >/dev/null 2>&1; then
    # Clear git env vars for cargo-deny's subprocess call chain.
    #
    # cargo-deny's advisories check updates the rustsec advisory database
    # clone under ~/.cargo/advisory-db/ via an internal `git fetch` +
    # `git reset --mixed FETCH_HEAD` sequence. Those internal git calls
    # inherit the parent's git env vars - and when the parent is a
    # pre-commit hook invoked by `git commit`, git has already set
    # GIT_DIR and GIT_INDEX_FILE to point at THIS worktree. With those
    # inherited, cargo-deny's advisory-db `git reset --mixed FETCH_HEAD`
    # silently resets OUR index to match HEAD's tree, clobbering the
    # staged changes the user is about to commit. The resulting commit
    # object ends up with an empty tree (matching HEAD's tree) or the
    # final `git commit` HEAD-update fails with
    # `cannot lock ref 'HEAD'` when the inherited GIT_DIR reset moves
    # HEAD mid-pre-commit. Either way the commit is broken.
    #
    # The pre-push hook already uses the same `unset` dance around
    # `cargo test` for the analogous reason (tests that shell out to
    # git must not touch this repo); we apply the same pattern here.
    # The subshell `(` scopes the unset so subsequent checks in this
    # hook are unaffected.
    (
        unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE GIT_COMMON_DIR
        cargo deny check advisories licenses bans sources
    )
    echo "cargo-deny OK."
else
    echo "cargo-deny not installed; skipping. Install with: cargo install cargo-deny"
fi

echo "=== pre-commit: cargo-machete (skipped if tool missing) ==="
if command -v cargo-machete >/dev/null 2>&1; then
    cargo machete
    echo "cargo-machete OK."
else
    echo "cargo-machete not installed; skipping. Install with: cargo install cargo-machete"
fi
